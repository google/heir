
// LoLA MNIST CNN
// originally from "Low Latency Privacy Preserving Inference", Brutzkus et al.,
// but made FHE-friendly by replacing activations with x^2 as in Orion:
// https://github.com/baahl-nyu/orion/blob/main/orion/models/lola.py
// one stride-2 Conv2D, quadratic (x^2) activations, and two dense layers.
// The model weights are embedded in the source MLIR as dense_resource constants.
#map = affine_map<(d0, d1, d2, d3) -> (d0, d1, d2, d3)>
#map1 = affine_map<(d0, d1) -> (d0, d1)>
#map2 = affine_map<(d0, d1) -> (d1)>
module {
  func.func @lola(%arg0: tensor<1x1x28x28xf32> {secret.secret}) -> tensor<1x10xf32> {
    %cst = arith.constant 0.000000e+00 : f32
    %cst_0 = arith.constant dense_resource<torch_tensor_10_torch.float32> : tensor<10xf32>
    %cst_1 = arith.constant dense_resource<torch_tensor_10_100_torch.float32> : tensor<10x100xf32>
    %cst_2 = arith.constant dense_resource<torch_tensor_100_torch.float32> : tensor<100xf32>
    %cst_3 = arith.constant dense_resource<torch_tensor_100_1568_torch.float32> : tensor<100x1568xf32>
    %cst_4 = arith.constant dense_resource<torch_tensor_8_1_2_2_torch.float32> : tensor<8x1x2x2xf32>
    %cst_5 = arith.constant dense_resource<torch_tensor_8_torch.float32> : tensor<8xf32>
    %0 = tensor.empty() : tensor<1x8x14x14xf32>
    %broadcasted = linalg.broadcast ins(%cst_5 : tensor<8xf32>) outs(%0 : tensor<1x8x14x14xf32>) dimensions = [0, 2, 3]
    %1 = linalg.conv_2d_nchw_fchw {dilations = dense<1> : vector<2xi64>, strides = dense<2> : vector<2xi64>} ins(%arg0, %cst_4 : tensor<1x1x28x28xf32>, tensor<8x1x2x2xf32>) outs(%broadcasted : tensor<1x8x14x14xf32>) -> tensor<1x8x14x14xf32>
    %2 = linalg.generic {indexing_maps = [#map, #map, #map], iterator_types = ["parallel", "parallel", "parallel", "parallel"]} ins(%1, %1 : tensor<1x8x14x14xf32>, tensor<1x8x14x14xf32>) outs(%0 : tensor<1x8x14x14xf32>) {
    ^bb0(%in: f32, %in_7: f32, %out: f32):
      %14 = arith.mulf %in, %in_7 : f32
      linalg.yield %14 : f32
    } -> tensor<1x8x14x14xf32>
    %collapsed = tensor.collapse_shape %2 [[0], [1, 2, 3]] : tensor<1x8x14x14xf32> into tensor<1x1568xf32>
    %3 = tensor.empty() : tensor<1568x100xf32>
    %transposed = linalg.transpose ins(%cst_3 : tensor<100x1568xf32>) outs(%3 : tensor<1568x100xf32>) permutation = [1, 0]
    %4 = tensor.empty() : tensor<1x100xf32>
    %5 = linalg.fill ins(%cst : f32) outs(%4 : tensor<1x100xf32>) -> tensor<1x100xf32>
    %6 = linalg.matmul ins(%collapsed, %transposed : tensor<1x1568xf32>, tensor<1568x100xf32>) outs(%5 : tensor<1x100xf32>) -> tensor<1x100xf32>
    %7 = linalg.generic {indexing_maps = [#map1, #map2, #map1], iterator_types = ["parallel", "parallel"]} ins(%6, %cst_2 : tensor<1x100xf32>, tensor<100xf32>) outs(%4 : tensor<1x100xf32>) {
    ^bb0(%in: f32, %in_7: f32, %out: f32):
      %14 = arith.addf %in, %in_7 : f32
      linalg.yield %14 : f32
    } -> tensor<1x100xf32>
    %8 = linalg.generic {indexing_maps = [#map1, #map1, #map1], iterator_types = ["parallel", "parallel"]} ins(%7, %7 : tensor<1x100xf32>, tensor<1x100xf32>) outs(%4 : tensor<1x100xf32>) {
    ^bb0(%in: f32, %in_7: f32, %out: f32):
      %14 = arith.mulf %in, %in_7 : f32
      linalg.yield %14 : f32
    } -> tensor<1x100xf32>
    %9 = tensor.empty() : tensor<100x10xf32>
    %transposed_6 = linalg.transpose ins(%cst_1 : tensor<10x100xf32>) outs(%9 : tensor<100x10xf32>) permutation = [1, 0]
    %10 = tensor.empty() : tensor<1x10xf32>
    %11 = linalg.fill ins(%cst : f32) outs(%10 : tensor<1x10xf32>) -> tensor<1x10xf32>
    %12 = linalg.matmul ins(%8, %transposed_6 : tensor<1x100xf32>, tensor<100x10xf32>) outs(%11 : tensor<1x10xf32>) -> tensor<1x10xf32>
    %13 = linalg.generic {indexing_maps = [#map1, #map2, #map1], iterator_types = ["parallel", "parallel"]} ins(%12, %cst_0 : tensor<1x10xf32>, tensor<10xf32>) outs(%10 : tensor<1x10xf32>) {
    ^bb0(%in: f32, %in_7: f32, %out: f32):
      %14 = arith.addf %in, %in_7 : f32
      linalg.yield %14 : f32
    } -> tensor<1x10xf32>
    return %13 : tensor<1x10xf32>
  }
}

