// RUN: heir-opt --linalg-canonicalizations --split-input-file %s | FileCheck %s

#map = affine_map<(d0, d1, d2, d3) -> (d0, d1, d2, d3)>
module {
  // CHECK: func.func @main
  // CHECK: linalg.conv_2d_nchw_fchw
  // CHECK-NOT: arith.divf
  // CHECK: return
  func.func @main(%arg0: tensor<1x6x28x28xf32>) -> tensor<1x6x14x14xf32> {
    %cst = arith.constant dense<""> : tensor<6x6x2x2xf32>
    %cst_0 = arith.constant dense<2.000000e+00> : tensor<1x6x14x14xf32>
    %cst_1 = arith.constant dense<4.000000e+00> : tensor<1x6x14x14xf32>
    %1 = linalg.conv_2d_nchw_fchw {dilations = dense<1> : vector<2xi64>, strides = dense<2> : vector<2xi64>} ins(%arg0, %cst : tensor<1x6x28x28xf32>, tensor<6x6x2x2xf32>) outs(%cst_0 : tensor<1x6x14x14xf32>) -> tensor<1x6x14x14xf32>
    %2 = arith.divf %1, %cst_1 : tensor<1x6x14x14xf32>
    return %2 : tensor<1x6x14x14xf32>
  }
}
